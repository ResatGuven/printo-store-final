import { prisma } from '@/lib/prisma'
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/auth'
import { redirect } from 'next/navigation'
import DashboardClient from './DashboardClient'

async function getStats() {
  const [
    totalProducts,
    activeOrders,
    totalRevenue,
    recentOrders,
    filamentStocks,
    ordersByStatus,
    lowStockProducts,
  ] = await Promise.all([
    prisma.product.count({ where: { active: true } }),
    prisma.order.count({ where: { status: { in: ['PENDING', 'PRINTING', 'QUALITY_CHECK'] } } }),
    prisma.order.aggregate({ where: { status: 'DELIVERED' }, _sum: { total: true } }),
    prisma.order.findMany({
      take: 6,
      orderBy: { createdAt: 'desc' },
      include: {
        customer: { select: { name: true, email: true } },
        items: {
          take: 1,
          include: { product: { select: { name: true, filament: true } } },
        },
      },
    }),
    prisma.filamentStock.findMany({ orderBy: { weightKg: 'asc' } }),
    prisma.order.groupBy({ by: ['status'], _count: { _all: true } }),
    prisma.product.findMany({
      where: { stock: { lte: 3 }, active: true },
      orderBy: { stock: 'asc' },
      take: 5,
    }),
  ])

  // Son 7 gün günlük sipariş sayıları
  const days: { label: string; count: number }[] = []
  for (let i = 6; i >= 0; i--) {
    const d = new Date()
    d.setDate(d.getDate() - i)
    d.setHours(0, 0, 0, 0)
    const next = new Date(d)
    next.setDate(next.getDate() + 1)
    const count = await prisma.order.count({
      where: { createdAt: { gte: d, lt: next } },
    })
    days.push({
      label: d.toLocaleDateString('tr-TR', { weekday: 'short' }),
      count,
    })
  }

  return {
    totalProducts,
    activeOrders,
    totalRevenue: Number(totalRevenue._sum.total ?? 0),
    recentOrders,
    filamentStocks,
    ordersByStatus,
    lowStockProducts,
    weeklyData: days,
  }
}

export default async function DashboardPage() {
  const session = await getServerSession(authOptions)
  if (!session) redirect('/admin/login')

  const stats = await getStats()
  return <DashboardClient stats={stats} />
}
